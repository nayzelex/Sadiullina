<Window x:Class="Sadiullina.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Sadiullina"
        Title="Мастер пол - Учет партнеров" 
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <DockPanel Margin="0">
        <!-- МЕНЮ ПРОГРАММЫ -->
        <Menu DockPanel.Dock="Top" Background="#1976D2" Height="40" Foreground="White">
            <MenuItem Header="Файл" Foreground="White">
                <MenuItem Header="Выход" Click="ExitMenuItem_Click" Foreground="Black"/>
            </MenuItem>

            <MenuItem Header="Партнеры" Foreground="White">
                <MenuItem Header="Добавить партнера" Click="AddPartnerMenuItem_Click" Foreground="Black">
                    <MenuItem.Icon>
                        <TextBlock Text="➕" Margin="5,0"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="Редактировать" Click="EditPartnerMenuItem_Click" Foreground="Black"/>
                <MenuItem Header="Удалить" Click="DeletePartnerMenuItem_Click" Foreground="Black"/>
                <Separator/>
                <MenuItem Header="История продаж" Click="HistoryMenuItem_Click" Foreground="Black"/>
            </MenuItem>

            <MenuItem Header="Справка" Foreground="White">
                <MenuItem Header="О программе" Click="AboutMenuItem_Click" Foreground="Black"/>
            </MenuItem>
        </Menu>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: ПАРТНЕРЫ -->
            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#2196F3" CornerRadius="5,5,0,0" Padding="10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="ПАРТНЕРЫ" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <Button Grid.Column="1" Content="➕" Width="30" Height="30" 
                                Background="Transparent" BorderThickness="0" Foreground="White"
                                FontSize="18" FontWeight="Bold" Cursor="Hand"
                                Click="AddPartnerMenuItem_Click"
                                ToolTip="Добавить партнера"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" 
                              Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding Partners}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" Margin="5"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" 
                                        BorderBrush="#E0E0E0"
                                        BorderThickness="1"
                                        CornerRadius="5"
                                        Margin="5"
                                        Padding="10"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        MouseLeftButtonUp="PartnerCard_MouseLeftButtonUp">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                                   FontSize="14" FontWeight="Bold" 
                                                   Foreground="#333333"
                                                   Text="{Binding CompanyName}"/>

                                        <Border Grid.Row="0" Grid.Column="1" 
                                                Background="#4CAF50" CornerRadius="15" 
                                                Padding="8,2" Margin="5,0">
                                            <TextBlock Text="{Binding DiscountPercentage, StringFormat='{}{0}%'}" 
                                                       Foreground="White" FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                   Text="{Binding DirectorFullname}" 
                                                   Foreground="#666666" FontSize="12"
                                                   Margin="0,5,0,2"/>

                                        <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Phone}" 
                                                       Foreground="#666666" FontSize="12"/>
                                        </StackPanel>

                                        <TextBlock Grid.Row="2" Grid.Column="1" 
                                                   Text="{Binding Rating, StringFormat='Рейтинг: {0}'}" 
                                                   Foreground="#FF9800" FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- ПРАВАЯ ПАНЕЛЬ: ЗАКАЗЫ -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FF9800" CornerRadius="5,5,0,0" Padding="10">
                    <TextBlock Text="{Binding SelectedPartner.CompanyName, StringFormat='ЗАКАЗЫ: {0}'}" 
                               Foreground="White" FontWeight="Bold" FontSize="16"/>
                </Border>

                <ScrollViewer Grid.Row="1" Background="White" BorderBrush="#CCCCCC" 
                              BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding SelectedPartnerOrders}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical" Margin="10"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#F8F9FA" BorderBrush="#E0E0E0" 
                                        BorderThickness="1" CornerRadius="5" 
                                        Margin="5" Padding="10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{Binding FormattedSaleDate}" 
                                                   Foreground="#666666" FontSize="12" 
                                                   VerticalAlignment="Center" Width="80"/>

                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}" 
                                                   Foreground="#333333" FontSize="13" 
                                                   FontWeight="SemiBold" Margin="10,0"/>

                                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Quantity, StringFormat='\{0\} шт'}"  
                                                       Foreground="#666666" FontSize="12" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding FormattedTotalAmount}" 
                                                       Foreground="#4CAF50" FontWeight="Bold" FontSize="13"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </DockPanel>
</Window>