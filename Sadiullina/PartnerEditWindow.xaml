<Window x:Class="Sadiullina.PartnerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding WindowTitle}" 
        Height="600" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding WindowTitle}" 
                   Style="{StaticResource HeaderStyle}"
                   HorizontalAlignment="Center"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,20">

                <TextBlock Text="Тип партнера *" Margin="5,10,5,2"/>
                <ComboBox ItemsSource="{Binding PartnerTypes}"
                          SelectedItem="{Binding SelectedType}"
                          DisplayMemberPath="Name"
                          Margin="5"
                          Padding="5"/>

                <TextBlock Text="Наименование *" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.CompanyName, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Юридический адрес" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.LegalAddress}"
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="ИНН" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.Inn}"
                         Style="{StaticResource TextBoxStyle}"
                         MaxLength="12"/>

                <TextBlock Text="ФИО директора" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.DirectorFullname}"
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Телефон" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.Phone}"
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Email" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.Email}"
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="Рейтинг (0-1000) *" Margin="5,10,5,2"/>
                <TextBox Text="{Binding CurrentPartner.Rating}"
                         Style="{StaticResource TextBoxStyle}"/>

                <TextBlock Text="* - обязательные поля" 
                           Margin="5,20,5,5"
                           Foreground="Gray"
                           FontStyle="Italic"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Сохранить" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding SaveCommand}"/>

            <Button Content="Отмена" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Background="#9E9E9E"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>

        <Grid Grid.Row="1" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="50" Height="50" IsIndeterminate="True"/>
                <TextBlock Text="Загрузка..." Margin="0,10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>