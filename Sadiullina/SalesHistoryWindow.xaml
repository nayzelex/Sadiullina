<Window x:Class="Sadiullina.SalesHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История продаж" 
        Height="500" Width="800"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}" 
                   Style="{StaticResource HeaderStyle}"
                   HorizontalAlignment="Center"/>

        <Border Grid.Row="1" Background="#E3F2FD" CornerRadius="5" Padding="10" Margin="0,10">
            <StackPanel>
                <TextBlock Text="{Binding DiscountInfo}" 
                           FontSize="16" 
                           FontWeight="SemiBold"
                           Foreground="#1976D2"/>
                <TextBlock Text="{Binding TotalSalesAmount, StringFormat='Общая сумма продаж: {0:N2} ₽'}" 
                           FontSize="14"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding SalesHistory}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  Margin="0,10">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Дата" Binding="{Binding FormattedSaleDate}" Width="100"/>
                <DataGridTextColumn Header="Продукт" Binding="{Binding ProductName}" Width="200"/>
                <DataGridTextColumn Header="Артикул" Binding="{Binding ProductArticle}" Width="80"/>
                <DataGridTextColumn Header="Количество" Binding="{Binding Quantity}" Width="80"/>
                <DataGridTextColumn Header="Сумма" Binding="{Binding FormattedTotalAmount}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Background="#80FFFFFF" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar Width="50" Height="50" IsIndeterminate="True"/>
                <TextBlock Text="Загрузка истории..." Margin="0,10" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>